<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Regression Suite – Full test suite covering all 26 implemented test cases.
  Run nightly or before releases.
-->
<suite name="Regression Test Suite" verbose="1" thread-count="1">

    <listeners>
        <listener class-name="com.automationexercise.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>

    <test name="Authentication Tests">
        <classes>
            <class name="com.automationexercise.tests.authentication.LoginTest"/>
        </classes>
    </test>

    <test name="Registration Tests">
        <classes>
            <class name="com.automationexercise.tests.registration.RegistrationTest"/>
        </classes>
    </test>

    <test name="Contact Tests">
        <classes>
            <class name="com.automationexercise.tests.contact.ContactUsTest"/>
        </classes>
    </test>

    <test name="Products Tests">
        <classes>
            <class name="com.automationexercise.tests.products.ProductsTest"/>
            <class name="com.automationexercise.tests.products.ProductSearchTest"/>
            <class name="com.automationexercise.tests.products.CategoryBrandTest"/>
            <class name="com.automationexercise.tests.products.ReviewTest"/>
        </classes>
    </test>

    <test name="Subscription Tests">
        <classes>
            <class name="com.automationexercise.tests.subscription.SubscriptionTest"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="com.automationexercise.tests.cart.CartTest"/>
        </classes>
    </test>

    <test name="Checkout Tests">
        <classes>
            <class name="com.automationexercise.tests.checkout.CheckoutTest"/>
        </classes>
    </test>

    <test name="Scroll Tests">
        <classes>
            <class name="com.automationexercise.tests.scroll.ScrollTest"/>
        </classes>
    </test>

</suite>
