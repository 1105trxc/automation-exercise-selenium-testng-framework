<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    SMOKE SUITE – Run the most critical test cases to validate the framework is working.

    PURPOSE: Quick sanity check (~5-10 min) before any deployment or merge.
    If smoke suite fails, stop immediately – no point running regression.

    RUN COMMAND:
      mvn clean test
      (or explicitly: mvn clean test -DsuiteXmlFile=src/test/resources/suites/smoke.xml)

    OVERRIDE BROWSER:
      mvn clean test -Dbrowser=firefox
      mvn clean test -Dheadless=true
-->
<suite name="Smoke Test Suite" verbose="1" thread-count="1">

    <!-- Default browser: can be overridden by -Dbrowser=firefox -->
    <parameter name="browser" value="chrome"/>

    <test name="Authentication – Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automationexercise.tests.authentication.LoginTest"/>
        </classes>
    </test>

</suite>
