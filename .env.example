# Environment Configuration Example
# Copy this file to src/main/resources/config/local.properties and fill in your values.
# NEVER commit local.properties to Git (it's in .gitignore).

baseUrl=https://automationexercise.com
browser=chrome
headless=false
explicitWait=15
pageLoadTimeout=30
downloadDir=target/downloads
thirdPartyAdWorkaround=true
